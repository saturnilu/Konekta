# Server
PORT=4000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=konekta

# JWT
JWT_SECRET=change-this-to-a-random-secret
TOKEN_EXPIRY_HOURS=24

# RapidAPI TikTok (untuk fetch video stats)
